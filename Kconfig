config SMARTGATEWAY_WIFI_STATIC_IP
	string "WiFi 인터페이스 정적 IPv4 주소"
	default "10.108.214.151"
	help
	  이더넷(NET_CONFIG_MY_IPV4_ADDR)과 충돌하지 않도록 별도 IP를 지정합니다.
	  prj.conf: CONFIG_SMARTGATEWAY_WIFI_STATIC_IP="x.x.x.x"

config SMARTGATEWAY_WIFI_STATIC_NETMASK
	string "WiFi 인터페이스 서브넷 마스크"
	default "255.255.255.0"

config SMARTGATEWAY_WIFI_STATIC_GW
	string "WiFi 인터페이스 기본 게이트웨이"
	default "10.108.214.1"

config SMARTGATEWAY_WIFI_TCP_PEER_IP
	string "WiFi TCP 상대(서버) IPv4"
	default "192.168.88.3"
	help
	  NVS의 wifi_tcp_server_ip 기본값.

config SMARTGATEWAY_WIFI_TCP_PEER_PORT
	int "WiFi TCP 상대 포트"
	default 20273
	range 1 65535

config SMARTGATEWAY_DEFER_WIFI_CONNECT_MS
	int "WiFi 연결 시도 전 추가 지연 (ms, 0=없음)"
	default 0
	range 0 600000
	help
	  네트워크 매니저가 WiFi 연결 전 대기하는 시간(RAM/crypto 피크 분산 등).

config SMARTGATEWAY_WIFI_WPA3_TRANSITION_AP
	bool "WPA3 전환(AP 혼합) — wifi 확장·문서용"
	default n

config SMARTGATEWAY_WIFI_WPA3_MFP_REQUIRED
	bool "PMF(802.11w) 필수 — wifi 확장·문서용"
	default n

config SMARTGATEWAY_WIFI_SCAN_BAND_2_4_GHZ
	bool "2.4GHz 스캔 우선 — wifi 확장·문서용"
	default n

config SMARTGATEWAY_WIFI_FIXED_CHANNEL
	int "고정 WiFi 채널 (0=전체 스캔)"
	default 0
	range 0 255

config SMARTGATEWAY_WIFI_TEST_NO_ETH
	bool "테스트: WiFi-only 오버레이(이더넷 생략·별도 conf와 함께)"
	default n
	help
	  일부 빌드에서 ETH를 제외할 때 netmgr 로그용. prj_wifi_only_test.conf 등과 함께 사용.

endif # SMARTGATEWAY_WIFI_ENABLE

config SMARTGATEWAY_WIFI_WIRING_EVB_MAYA
	bool "EVK-MAYA-W166 배선 (wifi_maya_rails.c 제외)"
	default n
	depends on SMARTGATEWAY_WIFI_ENABLE
	help
	  y이면 EVB-MAYA 전원 레일이 J3 VBUS_SDIO 로 공급되므로
	  wifi_maya_rails.c (P4_ GPIO 제어) 를 빌드에서 제외합니다.
	  prj.conf: CONFIG_SMARTGATEWAY_WIFI_WIRING_EVB_MAYA=y

