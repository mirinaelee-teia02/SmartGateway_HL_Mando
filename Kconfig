	default "10.108.214.1"

config SMARTGATEWAY_ETH_TCP_PEER_IP
	string "이더넷 TCP 상대(서버) IPv4"
	default "10.108.214.100"
	help
	  NVS의 eth_tcp_server_ip 기본값. TCP Modbus 게이트가 listen 할 때 상대 PC 주소.

config SMARTGATEWAY_ETH_TCP_PEER_PORT
	int "이더넷 TCP 상대 포트"
	default 20273
	range 1 65535

comment "── WiFi UDP ─────────────────────────────────────"

config SMARTGATEWAY_WIFI_UDP_PEER_IP
	string "WiFi UDP 전송 목적지 IPv4"
	default "192.168.5.100"
	help
	  WiFi 인터페이스로 ADC 패킷을 보낼 상대 주소.
	  prj.conf: CONFIG_SMARTGATEWAY_WIFI_UDP_PEER_IP="x.x.x.x"

config SMARTGATEWAY_WIFI_UDP_PEER_PORT
	int "WiFi UDP 전송 목적지 포트"
	default 20263
	range 1 65535

config SMARTGATEWAY_WIFI_UDP_BIND_PORT
	int "WiFi UDP 수신 바인드 포트 (0이면 recv 안 함)"
	default 0
	range 0 65535
	help
	  0 보다 크면 해당 포트에 bind 하고 recvfrom 으로 수신합니다.
	  SMARTGATEWAY_TCP_MODBUS_GATEWAY 사용 시 TCP MsgType 0x01(SYNC) 수신 전까지
	  UDP 수신은 하지 않습니다.

config SMARTGATEWAY_UDP_TEST_MODE
	bool "UDP 테스트 페이로드 (MessagePack array 4요소)"
	default n
	help
	  y이면 [ device_str, ts(17자), f32, f32 ] 형태의 MessagePack 배열만 전송합니다.
	  페이로드의 float 두 개는 항상 LPADC에서 읽은 snap->raw[0], raw[1] 실측값입니다.
	  운영(map)은 이 옵션을 끄면 됩니다.
	  prj.conf: CONFIG_SMARTGATEWAY_UDP_TEST_MODE=y

config SMARTGATEWAY_ADC_CHANNEL_COUNT
	int "LPADC 변환 채널 수 (1~8)"
	default 8
	range 1 8
	help
	  adc_task 가 변환하는 채널 개수(0..N-1, adc_inputs[] 와 순서 일치).
	  prj.conf 예: CONFIG_SMARTGATEWAY_ADC_CHANNEL_COUNT=2

config SMARTGATEWAY_RS232_ENABLE
	bool "RS-232 태스크 (UART ↔ MAX3232)"
	default n
	select SERIAL
	help
	  포트 0 = SmartGateway overlay 기준 flexcomm5 LPUART5 (MikroBUS P1_16 RX / P1_17 TX).
	  TCP Modbus 게이트웨이를 끄면 UDP(RS232_UDP_LISTEN_PORT) → UART 패스스루 스레드가 동작합니다.

if SMARTGATEWAY_RS232_ENABLE

