config SMARTGATEWAY_PROTO_DEVICE_ID
	int "(예비) 프로토콜 Device ID — 현재 TCP 외곽 프레임에 미사용"
	default 1
	range 0 2147483647
	depends on SMARTGATEWAY_TCP_MODBUS_GATEWAY

config SMARTGATEWAY_TCP_HANDSHAKE_POLL_MS
	int "접속 통보(0x80) 송신 주기·수신 대기 (ms)"
	default 2000
	range 500 60000
	depends on SMARTGATEWAY_TCP_MODBUS_GATEWAY

config SMARTGATEWAY_TCP_CONNECT_MASTER
	string "CONNECT(0x80) Body: 장비 마스터 코드 (일반 문자, ASCII 바이트로 송신)"
	default "KRWJARDU002"
	depends on SMARTGATEWAY_TCP_MODBUS_GATEWAY
	help
	  예: KRWJARDU001 → 전선상 바이트 4B 52 57 … (문자별 ASCII, 덤프에서는 16진으로 보임).
	  NUL 제외·최대 SMARTGATEWAY_TCP_MAX_BODY 범위까지 복사 후 버전 헥사를 이어 붙입니다.
	  prj.conf: CONFIG_SMARTGATEWAY_TCP_CONNECT_MASTER="KRWJARDU001"

config SMARTGATEWAY_TCP_CONNECT_VERSION_HEX
	string "CONNECT(0x80) Body: 버전 등 (마스터 뒤에 이어 붙음, 연속 16진)"
	default "020000"
	depends on SMARTGATEWAY_TCP_MODBUS_GATEWAY
	help
	  기본 020000 = 바이트 02 00 00 (예: 2.0.0). 서버 규격에 맞게 변경.
	  최종 Body = 마스터(ASCII, 가변) + IDX(1B) + 버전(3B, 헥사 디코드). NVS master_code 우선.

config SMARTGATEWAY_TCP_MAX_BODY
	int "외곽 프레임 Body 최대 길이 (바이트, 규격 최대 256)"
	default 256
	range 0 256
	depends on SMARTGATEWAY_TCP_MODBUS_GATEWAY
	help
	  RS-232·TCP Body 상한. TCP_STREAM_BUF 는 (5 + 이 값 + 1) 이상 권장 (STX+Type+Seq+Len_BE+Body+ETX).

config SMARTGATEWAY_TCP_RS232_RX_TIMEOUT_MS
	int "RS-232 응답 수신 최대 대기 (ms, 첫 바이트~프레임 끝)"
	default 800
	range 100 86400000
	depends on SMARTGATEWAY_TCP_MODBUS_GATEWAY
	help
	  장치 자동 응답: 수백 ms. 수동 시험·느린 장치는 3600000(1시간) 등까지 설정 가능.

config SMARTGATEWAY_TCP_RS232_INTER_FRAME_GAP_MS
	int "RS-232 한 프레임 종료: 마지막 바이트 후 무음 시간 (ms)"
	default 50
	range 20 5000
	depends on SMARTGATEWAY_TCP_MODBUS_GATEWAY
	help
	  Modbus RTU 규격은 ~3.5 문자 시간(115200에서 수십 ms 미만). 수동 타이핑·느린 송신이면
	  1000~2000처럼 크게 설정(무음이 이 시간 지나면 수신 완료로 간주).

config SMARTGATEWAY_TCP_STREAM_BUF
	int "TCP 클라이언트 스트림 누적 버퍼 크기"
	default 512
	range 256 8192
	depends on SMARTGATEWAY_TCP_MODBUS_GATEWAY
	help
	  최소 권장: 5 + SMARTGATEWAY_TCP_MAX_BODY + 1 (한 프레임).

config SMARTGATEWAY_TCP_START_DELAY_MS
	int "TCP 게이트웨이 태스크 시작 전 지연 (ms)"
	default 0
	range 0 600000
	depends on SMARTGATEWAY_TCP_MODBUS_GATEWAY
	help
	  부팅 직후 다른 태스크·네트워크 준비 시간 확보용.

