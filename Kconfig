	bool "WiFi 전용"

config SMARTGATEWAY_NET_MODE_BOTH
	bool "이더넷 + WiFi 동시"
	imply NET_CONFIG_SETTINGS

endchoice

config SMARTGATEWAY_WIFI_ENABLE
	bool
	default y if SMARTGATEWAY_NET_MODE_WIFI_ONLY || SMARTGATEWAY_NET_MODE_BOTH
	help
	  SMARTGATEWAY_NET_MODE 에서 자동 결정됩니다. 직접 수정하지 마세요.

