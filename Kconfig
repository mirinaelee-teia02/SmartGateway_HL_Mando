config SMARTGATEWAY_RS232_UDP_LISTEN_PORT
	int "RS-232 패스스루 UDP 수신 포트 (이 장치에 bind)"
	default 20264
	range 1 65535
	help
	  TCP Modbus 게이트웨이가 꺼져 있을 때, 이 포트로 들어오는 UDP 페이로드를 RS-232 포트 0으로 전달합니다.
	  서버(또는 PC)가 게이트웨이 IP:이 포트로 바이트 스트림을 보내면 됩니다.

config SMARTGATEWAY_RS232_MODBUS_POST_TX_DELAY_MS
	int "Modbus RTU: UART TX 직후 수신 전 지연 (ms, 0=비활성)"
	default 0
	range 0 100
	help
	  RS-485 트랜시버는 TX 후 버스 방향 전환·라인 안착 시간이 필요할 수 있습니다.
	  수 ms 넣으면 슬레이브 첫 바이트 유실을 줄일 때가 있습니다. 풀듀플렉스 RS-232만 쓰면 0 권장.

endif

config SMARTGATEWAY_TCP_MODBUS_GATEWAY
	bool "TCP STX/Len/MsgType/Seq + Body + Error+ETX, RS-232 Modbus 중계"
	default n
	depends on SMARTGATEWAY_RS232_ENABLE
	select NET_TCP
	help
	  외곽 CRC 없음. Header 5B + Body(최대 256) + Tail(Error+ETX).
	  TCP_CLIENT_MODE=n 이면 보드가 listen(서버). y 이면 보드가 peer에 connect(클라이언트).
	  보드(클라이언트): 0x80 CONNECT(마스터+IDX+버전)를 HANDSHAKE_POLL_MS마다 송신.
	  서버: 0x01 SYNC(시각+RS-232). 보드: 0x81 ACK(Ret).
	  세션: 서버 0x02 Modbus 요청 → 보드 0x82(시각+응답).
	  RS-232 백그라운드 스레드(UDP 패스스루)는 띄우지 않습니다.

config SMARTGATEWAY_TCP_CLIENT_MODE
	bool "TCP 클라이언트: 원격 서버에 connect (보드는 클라이언트)"
	default y
	depends on SMARTGATEWAY_TCP_MODBUS_GATEWAY
	help
	  y이면 SMARTGATEWAY_TCP_PEER_IP:PEER_PORT 로 접속합니다. 원격(MCNX947 등)이
	  TCP 서버로 listen 해야 합니다.
	  n이면 SMARTGATEWAY_TCP_BIND_IP:LISTEN_PORT 에서 accept 하는 기존 동작입니다.

config SMARTGATEWAY_TCP_PEER_IP
	string "TCP peer IPv4 (클라이언트 모드: connect 대상 서버)"
	default "192.168.0.1"
	depends on SMARTGATEWAY_TCP_MODBUS_GATEWAY && SMARTGATEWAY_TCP_CLIENT_MODE

config SMARTGATEWAY_TCP_PEER_PORT
	int "TCP peer 포트 (클라이언트 모드)"
	default 5020
	range 1 65535
	depends on SMARTGATEWAY_TCP_MODBUS_GATEWAY && SMARTGATEWAY_TCP_CLIENT_MODE

config SMARTGATEWAY_TCP_RECONNECT_MS
	int "클라이언트: connect 실패·세션 종료 후 재시도 간격 (ms)"
	default 3000
	range 500 600000
	depends on SMARTGATEWAY_TCP_MODBUS_GATEWAY && SMARTGATEWAY_TCP_CLIENT_MODE

