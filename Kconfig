comment "보드(이 기기)의 고정 IPv4는 Zephyr 표준 옵션으로 prj.conf 에서 설정합니다:"
comment "  CONFIG_NET_CONFIG_MY_IPV4_ADDR, CONFIG_NET_CONFIG_MY_IPV4_GW, CONFIG_NET_CONFIG_MY_IPV4_NETMASK"

choice SMARTGATEWAY_NET_MODE
	prompt "네트워크 동작 모드"
	default SMARTGATEWAY_NET_MODE_BOTH
	help
	  prj.conf 에서 하나만 =y 로 설정하면 아래 항목이 자동 결정됩니다.
	    이더넷 IP 자동 설정(NET_CONFIG_SETTINGS)
	    WiFi 태스크 빌드(wifi_manager.c)

config SMARTGATEWAY_NET_MODE_ETH_ONLY
	bool "이더넷 전용"
	imply NET_CONFIG_SETTINGS

