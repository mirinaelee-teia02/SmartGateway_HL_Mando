# SmartGateway 앱 옵션 — west build 전 menuconfig / prj.conf 로 조정

menu "SmartGateway"

config SMARTGATEWAY_LINE_ID
	string "UDP/MessagePack line / DeviceID (최대 50자)"
	default "HL-MAND-SENSOR-001"
	help
	  line·DeviveID 필드에 쓰입니다. 50자 초과는 잘립니다(NUL 종료).
	  prj.conf 예: CONFIG_SMARTGATEWAY_LINE_ID="이름"

comment "── NVS 분할 부팅 (net_boot_mode) ───────────────"

config SMARTGATEWAY_NET_BOOT_DEFAULT
	int "NVS 기본 네트워크 모드 (0=WiFi 1=이더넷)"
	default 0
	range 0 1
	help
	  스키마 초기화 후 또는 load_defaults 시 NVS에 쓰이는 초기값.
	  0=WiFi: 유선 내리고 WiFi만 시도. 전부 실패 시 NVS를 1로 바꾸고 냉 재부팅.
	  1=이더넷: WiFi 단계 없음.
	  WiFi 비활성 빌드에서는 항상 이더넷(1)으로 고정된다.

config SMARTGATEWAY_FORCE_ETH_BOOT_MODE
	bool "부팅 시 NVS net_boot_mode를 이더넷(1)로 저장"
	default n
	help
	  한 번 플래시 후 재부팅하면 NVS가 유선 우선 모드로 덮어써진다.
	  FORCE_WIFI_BOOT_MODE 와 동시에 사용할 수 없음(menuconfig 가 배타 처리).

config SMARTGATEWAY_FORCE_WIFI_BOOT_MODE
	bool "부팅 시 NVS net_boot_mode를 WiFi(0)로 저장"
	default n
	depends on SMARTGATEWAY_WIFI_ENABLE
	depends on !SMARTGATEWAY_FORCE_ETH_BOOT_MODE
	help
	  한 번 빌드·플래시 후 재부팅하면 NVS의 분할 부팅 모드가 WiFi로 덮어써진다.
	  WiFi 테스트 후에는 이 옵션을 끄고 다시 빌드하면 된다.

comment "── 이더넷 UDP ──────────────────────────────────"

config SMARTGATEWAY_ETH_UDP_PEER_IP
	string "이더넷 UDP 전송 목적지 IPv4"
	default "10.108.214.100"
	help
	  이더넷 인터페이스로 ADC 패킷을 보낼 상대 주소.
	  prj.conf: CONFIG_SMARTGATEWAY_ETH_UDP_PEER_IP="x.x.x.x"

config SMARTGATEWAY_ETH_UDP_PEER_PORT
	int "이더넷 UDP 전송 목적지 포트"
	default 20263
	range 1 65535

config SMARTGATEWAY_ETH_UDP_BIND_PORT
	int "이더넷 UDP 수신 바인드 포트 (0이면 recv 안 함)"
	default 0
	range 0 65535

comment "── 이더넷 보드 IP·TCP 상대 (netmgr / NVS 기본값) ──"

