      "stopAtSymbol": "main",
      "isAttach": false,
      "toolchainPath": "C:/Users/leeyu/zephyr-sdk-0.17.4/arm-zephyr-eabi",
      "toolchainPrefix": "arm-zephyr-eabi-",
      "gdbInitCommands": [
        "set remotetimeout 600",
        "set non-stop off"
      ],
      "gdbServerLaunchTimeout": 300000,
      "gdbServerConfigs": {
        "linkserver": {},
        "segger": {
          "device": "MCXN947",
          "interface": "SWD",
          "speed": "4000"
        },
        "pemicro": {}
      },
      "showDevDebugOutput": "raw"
    },
    {
      "type": "mcuxpresso-debug",
      "name": "SmartGateway: LinkServer (MCU-Link, 구 FRDM 보드용)",
