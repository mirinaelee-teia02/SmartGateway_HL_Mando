      },
      "executableLoadTypePriority": "elf",
      "stopAtSymbol": "main",
      "isAttach": false,
      "toolchainPath": "C:/Users/leeyu/zephyr-sdk-0.17.4/arm-zephyr-eabi",
      "toolchainPrefix": "arm-zephyr-eabi-",
      "gdbInitCommands": [
        "set remotetimeout 600",
        "set non-stop off"
      ],
      "gdbServerLaunchTimeout": 300000,
      "debugServerLogFile": "${workspaceFolder}/debug/linkserver-mcux.log",
