{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "mcuxpresso-debug",
      "name": "SmartGateway: J-Link (빌드 후 플래시+디버그)",
      "request": "launch",
      "probeType": "SEGGER",
      "cwd": "${workspaceFolder}",
      "preLaunchTask": "Build SmartGateway (west)",
      "skipBuildBeforeDebug": true,
      "executable": {
        "elf": "${workspaceFolder}/debug/zephyr/zephyr.elf"
      },
      "executableLoadTypePriority": "elf",
      "stopAtSymbol": "main",
      "isAttach": false,
      "toolchainPath": "C:/Users/leeyu/zephyr-sdk-0.17.4/arm-zephyr-eabi",
      "toolchainPrefix": "arm-zephyr-eabi-",
      "gdbInitCommands": [
        "set remotetimeout 600",
        "set non-stop off"
      ],
      "gdbServerLaunchTimeout": 300000,
      "gdbServerConfigs": {
        "linkserver": {
          "device": "MCXN947:"
        },
        "segger": {
          "device": "MCXN947",
          "interface": "SWD",
          "speed": "4000"
        },
        "pemicro": {}
      },
      "showDevDebugOutput": "raw",
      "probeSerialNumber": "69406050"
    },
    {
      "type": "mcuxpresso-debug",
      "name": "SmartGateway: J-Link (빌드 생략, 빠른 연결)",
      "request": "launch",
